# LangGraph Legal Assistant Backend Environment Variables

# Required API Keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: LangSmith for debugging (recommended)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=ai-legal-assistant-langgraph

# Database Configuration (Optional - will use memory if not provided)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
REDIS_URL=redis://localhost:6379

# Vector Database (Optional)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Application Settings
DEBUG=false
CORS_ORIGINS=https://app.atornee.com,http://localhost:3000

# Heroku Specific (set automatically by Heroku)
PORT=8000 